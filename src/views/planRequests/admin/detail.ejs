<%- include('../../partials/header') %>

<main class="dashboard-page">
  <section class="dashboard-card plan-requests-section">
    <h1 class="dashboard-title"><%= planRequest.name %></h1>
    <p class="coach-request-meta">
      <strong>Trainee:</strong> <%= planRequest.trainee_name %>
      <span class="coach-request-email">&lt;<%= planRequest.trainee_email %>&gt;</span>
    </p>
    <p class="plan-requests-meta">
      <span class="plan-requests-status-badge status-<%= planRequest.status %>">Status: <%= planRequest.status.replace(/_/g, ' ') %></span>
      <% if (planRequest.created_at) { %>
        <span class="plan-requests-list-date">Created <%= new Date(planRequest.created_at).toLocaleString() %></span>
      <% } %>
    </p>

    <% if (planRequest.description) { %>
      <div class="plan-requests-body-block">
        <h2 class="plan-requests-subheading">Trainee description</h2>
        <p class="plan-requests-body-text"><%= planRequest.description %></p>
      </div>
    <% } %>

    <div class="plan-requests-body-block">
      <h2 class="plan-requests-subheading">Coach workout plan</h2>
      <% if (planRequest.workout_plan && planRequest.workout_plan.trim() !== '') { %>
        <pre class="plan-requests-workout-plan"><%= planRequest.workout_plan %></pre>
      <% } else { %>
        <p class="plan-requests-placeholder">No workout plan text yet.</p>
      <% } %>
    </div>

    <div class="plan-requests-detail-actions">
      <form
        method="post"
        action="/admin/plan-requests/<%= planRequest.id %>/delete"
        class="plan-requests-inline-form"
        onsubmit="return confirm('Delete this plan request permanently?');"
      >
        <button type="submit" class="plan-requests-button-danger">Delete request</button>
      </form>
    </div>

    <div class="dashboard-actions plan-requests-footer-actions">
      <a href="/admin/plan-requests" class="dashboard-link-secondary">All plan requests</a>
      <a href="/admin-dashboard" class="dashboard-link-secondary">Admin dashboard</a>
    </div>
  </section>
</main>

<%- include('../../partials/footer') %>
