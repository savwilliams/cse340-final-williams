<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/base.css">
</head>
<body class="<%= typeof bodyClass !== 'undefined' ? bodyClass : '' %>">
  <header class="site-header">
    <nav class="site-header-nav">
      <!-- Always visible links -->
      <a href="/">Home</a>

      <!-- Only visible when logged in -->
      <% if (isLoggedIn) { %>
        <% if (typeof dashboardPath !== 'undefined' && dashboardPath) { %>
          <a href="<%= dashboardPath %>">Dashboard</a>
        <% } %>
        <a href="/logout">Logout</a>
      <% } %>

      <!-- Only visible when NOT logged in -->
      <% if (!isLoggedIn) { %>
        <a href="/login">Login</a>
        <a href="/register">Register</a>
      <% } %>
    </nav>
    <div class="divider-line" aria-hidden="true"></div>
  </header>
