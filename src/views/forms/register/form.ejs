<!-- ========== Register Form ========== -->
<%- include('../../partials/header') %>
<main class="register-page">
  <section class="register-card">
    <div class="register-avatar" aria-hidden="true">
      <!-- Simple user icon -->
      <svg viewBox="0 0 24 24" role="img" aria-hidden="true" focusable="false">
        <path d="M12 12c2.761 0 5-2.239 5-5S14.761 2 12 2 7 4.239 7 7s2.239 5 5 5Zm0 2c-4.418 0-8 2.239-8 5v1h16v-1c0-2.761-3.582-5-8-5Z"/>
      </svg>
    </div>

    <h1><%= title %></h1>
    <p class="register-subtitle">
      Complete this form to create an account.
    </p>

    <form method="POST" action="/register" class="register-form">
      <div class="form-group">
        <label for="name">Name</label>
        <input type="text" id="name" name="name" required placeholder="Enter your Name" maxlength="50" class="register-input"/>
      </div>

      <div class="form-group">
        <label for="email">Email</label>
        <input type="email" id="email" name="email" required autocomplete="email" placeholder="Enter your email" class="register-input"/>
      </div>

      <div class="form-group">
        <label for="emailConfirm">Confirm email</label>
        <input type="email" id="emailConfirm" name="emailConfirm" required autocomplete="email" placeholder="Re-enter your email" class="register-input"/>
      </div>

      <div class="form-group">
        <label for="password">Password</label>
        <p id="password-requirements" class="register-help-text">
          At least 8 characters, including one number and one of: ! @ # $ % ^ &amp; *
        </p>
        <input type="password" id="password" name="password" minlength="8" required autocomplete="new-password" placeholder="Enter your password" class="register-input" pattern="(?=.*[0-9])(?=.*[!@#$%^&*]).*" title="Use at least 8 characters with a number and a special character (!@#$%^&*)" aria-describedby="password-requirements"/>
      </div>

      <div class="form-group">
        <label for="passwordConfirm">Confirm password</label>
        <input type="password" id="passwordConfirm" name="passwordConfirm" minlength="8" required autocomplete="new-password" placeholder="Re-enter your password" class="register-input" pattern="(?=.*[0-9])(?=.*[!@#$%^&*]).*" title="Must match password and meet the same rules"/>
      </div>

      <button type="submit" class="register-button">Create Account</button>

      <div class="form-footer">
        <p>Already have an account? <a href="/login">Login</a></p>
      </div>
    </form>
  </section>
</main>
<%- include('../../partials/footer') %>